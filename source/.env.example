# =====================================================================
# ZeroTrust - 운영 환경변수 템플릿 (L1-3)
#
# 사용법:
#   cp .env.example .env   # 그리고 값을 채워 넣는다
#   .env 는 절대 커밋하지 말 것 (.gitignore 에 명시되어 있음)
# =====================================================================

# ── SECRET_KEY (JWT 서명용) ──────────────────────────────────────────
# 32바이트 이상의 랜덤 값 필수.
# 예) python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# ── JWT 설정 ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=1
JWT_ISSUER=zerotrust-capstone
JWT_AUDIENCE=zerotrust-clients

# ── 데이터베이스 ──────────────────────────────────────────────────────
# PostgreSQL 만 지원한다.
# 예) postgresql://ztuser:password@db.internal:5432/zerotrust
DATABASE_URL=postgresql://ztuser:change-me@localhost:5432/zerotrust

# ── TOTP ─────────────────────────────────────────────────────────────
TOTP_ISSUER=ZeroTrustCapstone
TOTP_VALID_WINDOW=1

# ── 세션 만료 (초) ────────────────────────────────────────────────────
SESSION_IDLE_TIMEOUT_SEC=900
SESSION_HIGH_SENS_TIMEOUT_SEC=300
SESSION_ABSOLUTE_TIMEOUT_SEC=28800

# ── 계정 잠금 ────────────────────────────────────────────────────────
ACCOUNT_MAX_FAILED_LOGIN=5

# ── 사전 승인 TTL (초) ────────────────────────────────────────────────
PRE_APPROVAL_TTL_SEC=1800

# ── 서버 ─────────────────────────────────────────────────────────────
SERVER_PORT=8000

# ── 최초 관리자 부트스트랩 ────────────────────────────────────────────
# scripts/bootstrap_admin.py 직접 호출 시 사용.
# 부트스트랩이 끝나면 비밀번호를 변경하고 이 값들을 제거할 것.
# 빈 DB 가 아니면 bootstrap_admin 은 자체적으로 skip 한다.
# ADMIN_PASSWORD 는 최소 11자(권장 32자 이상 랜덤).
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_NAME=시스템 관리자
ADMIN_DEPT=정보보안과
ADMIN_RANK=관리자
ADMIN_WORK_DEVICE_ID=work-admin-001
ADMIN_LOCATION=본청
